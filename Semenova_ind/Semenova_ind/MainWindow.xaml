<Window x:Class="Semenova_ind.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Semenova_ind"
        mc:Ignorable="d"
        Title="Семенова - Учет партнеров" 
        Height="700" Width="1200"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style TargetType="MenuItem">
            <Setter Property="Foreground" Value="Black"/>
        </Style>

        <Style x:Key="CardItemStyle" TargetType="ListBoxItem">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="8">
                            <ContentPresenter/>
                        </Border>
                       
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DropShadowEffect x:Key="CardShadow" 
                          BlurRadius="5" 
                          Direction="-45" 
                          Opacity="0.1" 
                          ShadowDepth="2"/>

        <Style TargetType="TextBlock" x:Key="SectionHeaderStyle">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="10,0,0,10"/>
            <Setter Property="Foreground" Value="Black"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Menu Grid.Row="0" 
              Background="#FFE6E6E6"
              Height="40">
            <MenuItem Header="Файл">
                <MenuItem Header="Выход" Click="ExitMenuItem_Click"/>
            </MenuItem>
            <MenuItem Header="Партнеры">
                <MenuItem Header="Добавить партнера" Click="AddMenuItem_Click"/>
                <MenuItem Header="Редактировать партнера" Click="EditMenuItem_Click"/>
                <MenuItem Header="Удалить партнера" Click="DeleteMenuItem_Click"/>
            </MenuItem>
            <MenuItem Header="История заказов">
                <MenuItem Header="просмотреть историю заказов" Click="SayMenuItem_Click"/>
            </MenuItem>
        </Menu>

        <Grid Grid.Row="1" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="450"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" 
                    Background="White" 
                    BorderBrush="#FFCCCCCC" 
                    BorderThickness="1"
                    CornerRadius="5"
                    Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Список партнеров" 
                               Style="{StaticResource SectionHeaderStyle}"
                               Grid.Row="0"/>

                    <StackPanel Grid.Row="1" Margin="0,0,0,10">
                        <TextBox x:Name="SearchTextBox" 
                                 Height="30"
                                 Padding="5"
                                 TextChanged="SearchTextBox_TextChanged"
                                 ToolTip="Поиск по названию, директору, телефону"
                                 Background="White"
                                 BorderBrush="#FFCCCCCC">
                            <TextBox.Text>
                                <Binding Path="SearchTerm" UpdateSourceTrigger="PropertyChanged"/>
                            </TextBox.Text>
                        </TextBox>
                    </StackPanel>

                    <ListBox x:Name="PartnersListBox" 
                             Grid.Row="2"
                             SelectionMode="Single"
                             SelectionChanged="PartnersListBox_SelectionChanged"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             Background="Transparent"
                             BorderThickness="0"
                             ItemContainerStyle="{StaticResource CardItemStyle}">

                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Vertical"/>
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>

                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="White"
                                        BorderBrush="#FFCCCCCC"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="12"
                                        Margin="0,0,0,10"
                                        Effect="{StaticResource CardShadow}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,5">
                                            <TextBlock Text="{Binding TypeName}" 
                                                       FontSize="12"
                                                       Foreground="#FF666666"/>
                                            <TextBlock Text="{Binding Name}" 
                                                       FontSize="16"
                                                       FontWeight="Bold"
                                                       Foreground="Black"/>
                                        </StackPanel>

                                        <TextBlock Grid.Row="0" 
                                                   Grid.Column="1"
                                                   Text="{Binding CurrentDiscount, StringFormat={}{0}%}" 
                                                   Foreground="Black"
                                                   FontWeight="Bold"
                                                   FontSize="14"
                                                   VerticalAlignment="Top"
                                                   Margin="0,5,0,0"/>
                                        <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,5,0,5">
                                            <TextBlock Text="{Binding DirectorFullname}" 
                                                       FontSize="14"
                                                       Foreground="Black"/>
                                        </StackPanel>

                                        <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,5">
                                            <TextBlock Text="{Binding Phone}" 
                                                       FontSize="14"
                                                       Foreground="Black"/>
                                        </StackPanel>

                                        <StackPanel Grid.Row="3" Grid.Column="0" Orientation="Horizontal">
                                            <TextBlock Text="Рейтинг: " 
                                                       FontSize="14"
                                                       Foreground="#FF666666"/>
                                            <TextBlock Text="{Binding Rating}" 
                                                       FontSize="14"
                                                       FontWeight="Bold"
                                                       Foreground="Black"/>
                                        </StackPanel>

                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Width="5"
                          Background="Transparent"/>

            <Border Grid.Column="2" 
                    Background="White" 
                    BorderBrush="#FFCCCCCC" 
                    BorderThickness="1"
                    CornerRadius="5"
                    Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="OrdersHeaderTextBlock" 
                               Text="Список заказов выбранного партнера"
                               Style="{StaticResource SectionHeaderStyle}"
                               Grid.Row="0"/>

                    <Border x:Name="PartnerInfoPanel" 
                            Grid.Row="1"
                            Background="#FFF5F5F5"
                            Padding="10"
                            Margin="0,0,0,10"
                            CornerRadius="5"
                            BorderBrush="#FFCCCCCC"
                            BorderThickness="1"
                            Visibility="Collapsed">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,15,0">
                                <TextBlock Text="Директор:" Foreground="Black"/>
                                <TextBlock Text="Телефон:" Foreground="Black" Margin="0,5,0,0"/>
                                <TextBlock Text="Email:" Foreground="Black" Margin="0,5,0,0"/>
                                <TextBlock Text="Общая сумма:" Foreground="Black" Margin="0,5,0,0"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock x:Name="DirectorTextBlock" Text="-" FontWeight="SemiBold"/>
                                <TextBlock x:Name="PhoneTextBlock" Text="-" Margin="0,5,0,0"/>
                                <TextBlock x:Name="EmailTextBlock" Text="-" Margin="0,5,0,0"/>
                                <TextBlock x:Name="TotalSalesTextBlock" 
                                           Text="0 ₽" 
                                           FontWeight="Bold"
                                           Foreground="Black"
                                           Margin="0,5,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <ListView x:Name="OrdersListView" 
                              Grid.Row="2"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              Background="White"
                              BorderBrush="#FFCCCCCC">

                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Дата" Width="100">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding SaleDate, StringFormat=dd.MM.yyyy}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>

                                <GridViewColumn Header="Продукция" Width="300">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Product.Name}" 
                                                           FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding Product.Article}" 
                                                           FontSize="10"
                                                           Foreground="#FF666666"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>

                                <GridViewColumn Header="Кол-во" Width="100">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Quantity}" 
                                                       TextAlignment="Center"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>

                                <GridViewColumn Header="Цена" Width="200">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Product.Price, StringFormat={}{0:N2} ₽}" 
                                                       TextAlignment="Right"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <Button x:Name="AddOrderButton" 
                            Grid.Row="3"
                            Content="Добавить заказ"
                            Height="35"
                            Margin="0,10,0,0"
                            Background="#FFE6E6E6"
                            Foreground="Black"
                            BorderBrush="#FFCCCCCC"
                            BorderThickness="1"
                            Cursor="Hand"
                            Click="AddOrderButton_Click"
                            IsEnabled="False">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="5"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </Grid>
            </Border>
        </Grid>

        <StatusBar Grid.Row="2" 
                   Background="#FFE6E6E6"
                   Foreground="Black"
                   Height="25">
            <StatusBarItem>
                <TextBlock x:Name="StatusTextBlock" Text="{Binding StatusMessage}"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>