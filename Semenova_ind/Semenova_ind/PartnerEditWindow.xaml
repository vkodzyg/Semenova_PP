<Window x:Class="Semenova_ind.PartnerEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Semenova_ind"
        mc:Ignorable="d"
        Title="Семенова - Редактирование партнера" 
        Height="550" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style x:Key="EditLabelStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,5,0,0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#FF333333"/>
        </Style>

        <Style x:Key="EditTextBoxStyle" TargetType="TextBox">
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="BorderBrush" Value="#FFE0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style x:Key="EditComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="BorderBrush" Value="#FFE0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style x:Key="EditActionButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinWidth" Value="100"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style x:Key="EditBorderStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="5"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="TitleTextBlock" 
                   Text="Добавление нового партнера"
                   FontSize="20"
                   FontWeight="Bold"
                   Margin="0,0,0,20"
                   Foreground="#FF333333"
                   Grid.Row="0"/>

        <ScrollViewer Grid.Row="1" 
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <TextBlock Text="Тип партнера *" 
                           Style="{StaticResource EditLabelStyle}"/>
                <ComboBox x:Name="TypeComboBox" 
                          Style="{StaticResource EditComboBoxStyle}"
                          DisplayMemberPath="Name"
                          SelectedValuePath="Id"
                          ToolTip="Выберите тип партнера из списка"/>

                <TextBlock Text="Наименование компании *" 
                           Style="{StaticResource EditLabelStyle}"/>
                <TextBox x:Name="NameTextBox" 
                         Style="{StaticResource EditTextBoxStyle}"
                         MaxLength="200"
                         ToolTip="Введите полное наименование компании"/>

                <TextBlock Text="Юридический адрес" 
                           Style="{StaticResource EditLabelStyle}"/>
                <TextBox x:Name="AddressTextBox" 
                         Style="{StaticResource EditTextBoxStyle}"
                         MaxLength="500"
                         ToolTip="Введите юридический адрес компании"/>

                <TextBlock Text="ИНН" 
                           Style="{StaticResource EditLabelStyle}"/>
                <TextBox x:Name="InnTextBox" 
                         Style="{StaticResource EditTextBoxStyle}"
                         MaxLength="12"
                         ToolTip="Введите ИНН (10 или 12 цифр)"/>

                <TextBlock Text="ФИО Директора *" 
                           Style="{StaticResource EditLabelStyle}"/>
                <TextBox x:Name="DirectorTextBox" 
                         Style="{StaticResource EditTextBoxStyle}"
                         MaxLength="200"
                         ToolTip="Введите ФИО директора"/>

                <TextBlock Text="Телефон *" 
                           Style="{StaticResource EditLabelStyle}"/>
                <TextBox x:Name="PhoneTextBox" 
                         Style="{StaticResource EditTextBoxStyle}"
                         MaxLength="20"
                         ToolTip="Введите номер телефона"/>

                <TextBlock Text="Email *" 
                           Style="{StaticResource EditLabelStyle}"/>
                <TextBox x:Name="EmailTextBox" 
                         Style="{StaticResource EditTextBoxStyle}"
                         MaxLength="100"
                         ToolTip="Введите email адрес"/>

                <TextBlock Text="Рейтинг * 1-100" 
                           Style="{StaticResource EditLabelStyle}"/>
                <TextBox x:Name="RatingTextBox" 
                         Style="{StaticResource EditTextBoxStyle}"
                         PreviewTextInput="RatingTextBox_PreviewTextInput"
                         ToolTip="Введите рейтинг (целое неотрицательное число)"/>

               
              
                <TextBlock Text="* - обязательные поля" 
                           Foreground="#FF666666"
                           FontStyle="Italic"
                           FontSize="12"
                           Margin="0,10,0,0"/>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right"
                    Margin="0,20,0,0">
            <Button x:Name="SaveButton" 
                    Content="Сохранить"
                    Style="{StaticResource EditActionButtonStyle}"
                  
                    Foreground="Black"
                    Click="SaveButton_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="3"/>
                    </Style>
                </Button.Resources>
            </Button>

            <Button x:Name="CancelButton" 
                    Content="Отмена"
                    Style="{StaticResource EditActionButtonStyle}"
            
                    Foreground="Black"
                    Click="CancelButton_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="3"/>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>
    </Grid>
</Window>