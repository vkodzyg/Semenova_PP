<Window x:Class="Semenova_ind.AddSaleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Семенова - Добавление продажи" 
        Height="472" Width="574"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,5,0,0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Height" Value="30"/>
        </Style>

        <Style x:Key="ComboStyle" TargetType="ComboBox">
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Height" Value="30"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Добавление новой продажи" 
                   FontSize="18" FontWeight="Bold" 
                   Margin="0,0,0,20"
                   Grid.Row="0"/>

        <StackPanel Grid.Row="1">

            <TextBlock Text="Партнер" Style="{StaticResource LabelStyle}"/>
            <TextBox x:Name="PartnerNameTextBox" 
                     Style="{StaticResource InputStyle}"
                     IsReadOnly="True"
                     Background="#FFF0F0F0"/>

            <TextBlock Text="Продукция *" Style="{StaticResource LabelStyle}"/>
            <ComboBox x:Name="ProductComboBox" 
                      Style="{StaticResource ComboStyle}"
                      DisplayMemberPath="Name"
                      SelectedValuePath="Id"
                      IsEditable="True"
                      ToolTip="Выберите или введите название продукции"/>

            <TextBlock Text="Количество *" Style="{StaticResource LabelStyle}"/>
            <TextBox x:Name="QuantityTextBox" 
                     Style="{StaticResource InputStyle}"
                     PreviewTextInput="QuantityTextBox_PreviewTextInput"
                     ToolTip="Введите количество"/>

            <TextBlock Text="Дата продажи *" Style="{StaticResource LabelStyle}"/>
            <DatePicker x:Name="SaleDatePicker" 
                       SelectedDate="{Binding Date, Mode=TwoWay}"
                       DisplayDateStart="2020-01-01"
                       DisplayDateEnd="2026-12-31"
                       Margin="0,0,0,10"
                       Height="30"/>

            <TextBlock Text="* - обязательные поля" 
                       Foreground="Gray"
                       FontStyle="Italic"
                       Margin="0,10,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right"
                    Margin="0,20,0,0">
            <Button x:Name="SaveButton" 
                    Content="Сохранить"
                    Width="80" Height="35"
                    Margin="5"
                  
                    Foreground="Black"
                    BorderThickness="0"
                    Click="SaveButton_Click"/>

            <Button x:Name="CancelButton" 
                    Content="Отмена"
                    Width="80" Height="35"
                    Margin="5"
               
                    Foreground="Black"
                    BorderThickness="0"
                    Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>